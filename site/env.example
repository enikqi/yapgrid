# Application
APP_PORT=3002
NODE_ENV=development

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/pinreddit

# Redis
REDIS_URL=redis://localhost:6379

# Reddit API (prefer OAuth)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
# Optional, use only when admin activates:
REDDIT_SESSION_COOKIE=

# Pinterest API
PINTEREST_ACCESS_TOKEN=   # Business account token
PINTEREST_DEFAULT_BOARD_ID=

# Storage
STORAGE_DRIVER=local   # or s3
MEDIA_DIR=./media
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Video limits
MAX_DURATION_SECONDS=900
MAX_FILESIZE_MB=400

# Scheduler
CRON_INGEST=*/30 * * * *
CRON_PUBLISH=*/15 * * * *
QUEUE_CONCURRENCY=3

# NextAuth
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your-secret-key-here

# Email provider for magic links (optional)
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@pinreddit.com
